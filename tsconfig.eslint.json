{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@firegrid/client": ["packages/client/src/index.ts"],
      "@firegrid/client/*": ["packages/client/src/*"],
      "@firegrid/substrate": ["packages/substrate/src/index.ts"],
      "@firegrid/substrate/descriptors": ["packages/substrate/src/descriptors/index.ts"],
      "@firegrid/substrate/event-plane": ["packages/substrate/src/event-plane/index.ts"],
      "@firegrid/substrate/id-gen": ["packages/substrate/src/id-gen.ts"],
      "@firegrid/substrate/kernel": ["packages/substrate/src/kernel/index.ts"],
      "@firegrid/substrate/*": ["packages/substrate/src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "apps/**/*.ts",
    "apps/**/*.tsx"
  ]
}
