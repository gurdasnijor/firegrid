{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "src/index.ts",
        "src/host.ts",
        "scripts/**/*.mjs"
      ],
      "project": [
        "src/**/*.ts",
        "scripts/**/*.mjs"
      ]
    },
    "packages/client": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/protocol": {
      "entry": [
        "src/index.ts",
        "src/launch/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/runtime": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "apps/flamecast": {
      "project": [
        "src/**/*.{ts,tsx,mts}"
      ]
    },
    "scenarios/firegrid": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/effect-durable-streams": {
      "entry": [
        "src/index.ts",
        "test/**/*.test.ts",
        "test/**/*.bench.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    }
  },
  "ignore": [
    "semgrep-tests/**",
    "repos/**"
  ],
  "ignoreDependencies": [
    "jscpd"
  ],
  "ignoreBinaries": [
    "ruby",
    "semgrep"
  ]
}
