{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.mjs"
      ]
    },
    "apps/flamecast": {
      "project": [
        "src/**/*.{ts,tsx,mts}"
      ]
    },
    "scenarios/firegrid": {
      "project": [
        "src/**/*.ts"
      ]
    }
  },
  "ignore": [
    "semgrep-tests/**"
  ],
  "ignoreDependencies": [
    "jscpd"
  ],
  "ignoreBinaries": [
    "ruby",
    "semgrep"
  ]
}
