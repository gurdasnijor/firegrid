{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/cli": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/client-sdk": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/protocol": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/runtime": {
      "entry": [
        "src/bin/**/*.ts",
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "ignoreDependencies": [
        "@agentclientprotocol/claude-agent-acp"
      ]
    },
    "packages/effect-durable-operators": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/observability": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/tiny-firegrid": {
      "entry": [
        "src/bin/**/*.ts",
        "src/simulations/*/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ],
      "ignoreDependencies": [
        "@effect/ai",
        "@effect/workflow"
      ]
    },
    "packages/effect-durable-streams": {
      "entry": [
        "test/**/*.test.ts",
        "test/**/*.bench.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    }
  },
  "ignore": [
    "repos/**"
  ],
  "ignoreWorkspaces": [
    "tools/durable-streams-ui"
  ]
}
