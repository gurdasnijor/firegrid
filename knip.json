{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.mjs"
      ],
      "project": [
        "scripts/**/*.mjs"
      ]
    },
    "packages/cli": {
      "entry": [
        "src/bin/index.ts",
        "src/bin/run.ts",
        "src/bin/host.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/client": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/protocol": {
      "entry": [
        "src/index.ts",
        "src/launch/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/runtime": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/host-sdk": {
      "entry": [
        "src/index.ts",
        "src/host/index.ts",
        "src/agent-tools/index.ts",
        "src/agent-tools/bindings/index.ts",
        "src/agent-tools/execution/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/client-sdk": {
      "entry": [
        "src/index.ts",
        "src/firegrid.ts",
        "src/operations.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/effect-durable-operators": {
      "entry": [
        "src/index.ts",
        "src/react.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "apps/flamecast": {
      "project": [
        "src/**/*.{ts,tsx,mts}"
      ]
    },
    "scenarios/firegrid": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/effect-durable-streams": {
      "entry": [
        "src/index.ts",
        "test/**/*.test.ts",
        "test/**/*.bench.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    }
  },
  "ignore": [
    "semgrep-tests/**",
    "repos/**"
  ],
  "ignoreDependencies": [
    "@agentclientprotocol/sdk",
    "@modelcontextprotocol/sdk",
    "jscpd"
  ],
  "ignoreBinaries": [
    "ruby",
    "semgrep"
  ]
}
