{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.mjs"
      ],
      "project": [
        "scripts/**/*.mjs"
      ]
    },
    "packages/cli": {
      "entry": [
        "src/bin/index.ts",
        "src/bin/run.ts",
        "src/bin/host.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/client-sdk": {
      "entry": [
        "src/index.ts",
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/protocol": {
      "entry": [
        "src/index.ts",
        "src/launch/index.ts",
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/runtime": {
      "entry": [
        "src/index.ts",
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "ignoreDependencies": [
        "@agentclientprotocol/claude-agent-acp"
      ]
    },
    "packages/effect-durable-operators": {
      "entry": [
        "src/index.ts",
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/observability": {
      "entry": [
        "src/index.ts",
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/tiny-firegrid": {
      "entry": [
        "src/index.ts",
        "src/bin/**/*.ts",
        "src/simulations/*/index.ts",
        "src/simulations/*/*/index.ts",
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "ignoreFiles": [
        "src/simulations/to-be-migrated/**/*.ts",
        "src/prototypes/target-topology/**/*.ts"
      ],
      "ignoreDependencies": [
        "@firegrid/runtime",
        "effect-durable-operators"
      ]
    },
    "packages/effect-durable-streams": {
      "entry": [
        "src/index.ts",
        "test/**/*.test.ts",
        "test/**/*.bench.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "experiments/agent-coordination-patterns": {
      "entry": [
        "src/run.ts",
        "src/score.ts",
        "src/finding.ts",
        "src/report.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "tooling": {
      "entry": [
        "src/preflight.ts",
        "analysis/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "analysis/**/*.ts"
      ]
    }
  },
  "ignore": [
    "semgrep-tests/**",
    "repos/**"
  ],
  "ignoreDependencies": [
    "@agentclientprotocol/sdk",
    "@ast-grep/cli",
    "@modelcontextprotocol/sdk",
    "jscpd"
  ],
  "ignoreBinaries": [
    "ruby",
    "semgrep"
  ],
  "ignoreWorkspaces": [
    "tools/durable-streams-ui"
  ]
}
