{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.mjs"
      ],
      "project": [
        "scripts/**/*.mjs"
      ]
    },
    "packages/cli": {
      "entry": [
        "src/bin/index.ts",
        "src/bin/run.ts",
        "src/bin/host.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/client": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/protocol": {
      "entry": [
        "src/index.ts",
        "src/launch/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/runtime": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "apps/factory": {
      "entry": [
        "src/index.ts",
        "src/bin/live-smoke.ts",
        "src/bin/env.ts"
      ],
      "project": [
        "{app,components,lib,src}/**/*.{ts,tsx,mts}"
      ],
      "ignoreDependencies": [
        "tailwindcss",
        "tw-animate-css",
        "@tailwindcss/postcss",
        "postcss"
      ]
    },
    "apps/flamecast": {
      "project": [
        "src/**/*.{ts,tsx,mts}"
      ]
    },
    "scenarios/firegrid": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/tiny-firegrid": {
      "entry": [
        "src/index.ts",
        "src/simulations/*/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ],
      "ignoreFiles": [
        "src/simulations/to-be-migrated/**/*.ts"
      ],
      "ignoreDependencies": [
        "@firegrid/runtime",
        "effect-durable-operators"
      ]
    },
    "packages/effect-durable-streams": {
      "entry": [
        "src/index.ts",
        "test/**/*.test.ts",
        "test/**/*.bench.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    }
  },
  "ignore": [
    "semgrep-tests/**",
    "repos/**"
  ],
  "ignoreDependencies": [
    "@agentclientprotocol/sdk",
    "@ast-grep/cli",
    "@modelcontextprotocol/sdk",
    "jscpd"
  ],
  "ignoreBinaries": [
    "ruby",
    "semgrep"
  ]
}
