{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.mjs"
      ]
    },
    "packages/runtime": {
      "entry": [
        "src/index.ts",
        "bin/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "bin/**/*.ts"
      ]
    },
    "apps/flamecast": {
      "project": [
        "src/**/*.{ts,tsx,mts}"
      ]
    },
    "scenarios/firegrid": {
      "project": [
        "src/**/*.ts"
      ]
    }
  },
  "ignore": [
    "semgrep-tests/**"
  ],
  "ignoreDependencies": [
    "jscpd"
  ],
  "ignoreBinaries": [
    "ruby",
    "semgrep"
  ]
}
