{
  "name": "@durable-agent-substrate/host",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "pnpm run typecheck && pnpm run test",
    "dev:embedded": "tsx ./bin/dev-embedded.ts",
    "dev:lab": "pnpm run dev:embedded",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@durable-agent-substrate/client": "workspace:*",
    "@durable-agent-substrate/substrate": "workspace:*",
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/server": "^0.3.1",
    "@durable-streams/state": "^0.2.5",
    "effect": "^3.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
