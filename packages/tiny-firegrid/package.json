{
  "name": "@firegrid/tiny-firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/types.ts",
  "types": "./src/types.ts",
  "exports": {
    ".": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "overview": "effect-language-service overview --project tsconfig.json",
    "build": "tsc",
    "check": "pnpm run typecheck",
    "simulate": "tsx src/index.ts",
    "simulate:list": "tsx src/index.ts list",
    "simulate:perf": "tsx src/index.ts perf",
    "simulate:gate": "tsx src/index.ts gate",
    "simulate:gaps": "tsx src/index.ts gaps",
    "simulate:run": "tsx src/index.ts run",
    "simulate:seams": "tsx src/index.ts seams",
    "simulate:show": "tsx src/index.ts show",
    "simulate:runs": "tsx src/index.ts runs",
    "trace:seams": "tsx src/bin/trace-seams.ts",
    "trace:seams:ukv": "tsx src/bin/ukv-production-trace-gate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/ai": "^0.35.0",
    "@marcbachmann/cel-js": "7.6.1",
    "@effect/cli": "0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "0.75.1",
    "@effect/workflow": "0.18.1",
    "@firegrid/host-sdk": "workspace:*",
    "@firegrid/observability": "workspace:*",
    "@firegrid/protocol": "workspace:*",
    "@firegrid/runtime": "workspace:*",
    "effect": "^3.21.2",
    "effect-durable-operators": "workspace:*"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "0.21.0",
    "@durable-streams/server": "0.3.7",
    "@firegrid/client-sdk": "workspace:*",
    "@firegrid/fluent-firegrid": "workspace:*",
    "@firegrid/fluent-runtime": "workspace:*",
    "typescript": "^5.7.0"
  }
}
