{
  "name": "@firegrid/tiny-firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/types.ts",
  "types": "./src/types.ts",
  "exports": {
    ".": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck",
    "simulate": "tsx src/index.ts",
    "simulate:list": "tsx src/index.ts list",
    "simulate:run": "tsx src/index.ts run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/cli": "0.75.1",
    "@effect/opentelemetry": "0.63.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@firegrid/host-sdk": "workspace:*",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "effect": "^3.21.2",
    "effect-durable-operators": "workspace:*"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "0.21.0",
    "@durable-streams/server": "^0.3.1",
    "@firegrid/client-sdk": "workspace:*",
    "typescript": "^5.7.0"
  }
}
