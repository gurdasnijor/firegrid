{
  "name": "@firegrid/tiny-firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/types.ts",
  "types": "./src/types.ts",
  "exports": {
    ".": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./experiment": {
      "types": "./src/experiment/index.ts",
      "default": "./src/experiment/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck",
    "simulate": "tsx src/index.ts",
    "simulate:list": "tsx src/index.ts list",
    "simulate:perf": "tsx src/index.ts perf",
    "simulate:gate": "tsx src/index.ts gate",
    "simulate:run": "tsx src/index.ts run",
    "simulate:show": "tsx src/index.ts show",
    "simulate:runs": "tsx src/index.ts runs",
    "trace:seams:ukv": "tsx scripts/ukv-production-trace-gate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/cli": "0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "0.75.1",
    "@firegrid/observability": "workspace:*",
    "@firegrid/protocol": "workspace:*",
    "@firegrid/runtime": "workspace:*",
    "effect": "^3.21.2",
    "effect-durable-operators": "workspace:*"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "0.21.0",
    "@durable-streams/server": "^0.3.1",
    "@firegrid/client-sdk": "workspace:*",
    "typescript": "^5.7.0"
  }
}
