{
  "id": "acp-permission-tool-roundtrip",
  "description": "ACP-style transcript with provider-executed tool observation and permission request/resume evidence.",
  "provider": "local-process",
  "sessionMode": "codec",
  "transport": "ACP",
  "liveCanary": false,
  "faultClass": "happy-path",
  "verdict": "pass",
  "sourceBoundary": "byte-pipe stdout/stderr acquisition only",
  "codecBoundary": "ACP session updates normalize to AgentOutputEvent values",
  "durableEvidence": [
    "Ready row",
    "ToolUse row is observation-only for ACP",
    "PermissionRequest row",
    "PermissionResponse input row",
    "Terminated row"
  ],
  "frames": [
    { "stream": "stdout", "chunk": "{\"sessionUpdate\":\"agent_message_chunk\"," },
    { "stream": "stdout", "chunk": "\"content\":{\"type\":\"text\",\"text\":\"need approval\"}}\n" },
    { "stream": "stdout", "chunk": "{\"sessionUpdate\":\"tool_call\",\"toolCallId\":\"tool-acp-1\",\"title\":\"lookup\",\"rawInput\":{\"query\":\"firegrid\"}}\n" },
    { "stream": "stdin", "chunk": "{\"_tag\":\"PermissionResponse\",\"permissionRequestId\":\"perm-acp-1\",\"decision\":{\"_tag\":\"Allow\"}}\n" }
  ],
  "records": [
    { "direction": "output", "type": "ready", "toolUseMode": "control_channel_request_response" },
    { "direction": "output", "type": "text", "id": "msg-acp-1", "delta": "need approval" },
    { "direction": "output", "type": "tool_use", "toolUseId": "tool-acp-1", "name": "lookup", "input": { "query": "firegrid" }, "providerExecuted": true },
    { "direction": "output", "type": "permission_request", "permissionRequestId": "perm-acp-1", "toolUseId": "tool-acp-1" },
    { "direction": "input", "type": "permission_response", "permissionRequestId": "perm-acp-1", "decision": "Allow" },
    { "direction": "output", "type": "turn_complete", "finishReason": "stop", "messageId": "msg-acp-1" },
    { "direction": "output", "type": "terminated", "exitCode": 0 }
  ],
  "expected": {
    "outputEvents": 6,
    "inputEvents": 1,
    "permissionRequests": 1,
    "permissionResponses": 1,
    "toolUses": 1,
    "terminated": true,
    "secretsAbsent": true
  }
}
