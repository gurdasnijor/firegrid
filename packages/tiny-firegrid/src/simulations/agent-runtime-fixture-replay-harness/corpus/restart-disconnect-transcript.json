{
  "id": "restart-disconnect-after-committed-output",
  "description": "Adversarial restart/disconnect fixture: output commits, source disconnects, replay resumes without duplicating the committed row.",
  "provider": "local-process",
  "sessionMode": "raw",
  "transport": "raw-byte-stream",
  "liveCanary": false,
  "faultClass": "crash-mid-action",
  "verdict": "expected-fault",
  "sourceBoundary": "source reports early exit/disconnect; durable replay owns committed-row dedupe",
  "codecBoundary": "raw bytes stay raw output observations; no protocol correlation in source",
  "durableEvidence": [
    "Committed output row survives restart",
    "Replay does not duplicate committed output row",
    "Disconnect is terminal evidence"
  ],
  "frames": [
    { "stream": "stdout", "chunk": "partial action output" },
    { "stream": "stderr", "chunk": "process disconnected before action finished\n" }
  ],
  "records": [
    { "direction": "output", "type": "ready", "toolUseMode": "observation_only" },
    { "direction": "output", "type": "text", "id": "raw-committed-1", "delta": "partial action output" },
    { "direction": "output", "type": "error", "recoverable": true, "cause": "disconnect after committed output row" },
    { "direction": "output", "type": "terminated", "exitCode": 137 }
  ],
  "expected": {
    "outputEvents": 4,
    "inputEvents": 0,
    "permissionRequests": 0,
    "permissionResponses": 0,
    "toolUses": 0,
    "terminated": true,
    "secretsAbsent": true
  }
}
