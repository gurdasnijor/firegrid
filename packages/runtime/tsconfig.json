{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@firegrid/substrate": ["../substrate/src/index.ts"],
      "@firegrid/substrate/descriptors": ["../substrate/src/descriptors/index.ts"],
      "@firegrid/substrate/event-plane": ["../substrate/src/event-plane/index.ts"],
      "@firegrid/substrate/id-gen": ["../substrate/src/id-gen.ts"],
      "@firegrid/substrate/kernel": ["../substrate/src/kernel/index.ts"],
      "@firegrid/substrate/*": ["../substrate/src/*"]
    },
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": ["src/**/*.ts", "bin/**/*.ts"]
}
