{
  "name": "@firegrid/runtime",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./host-substrate": {
      "types": "./src/host-substrate.ts",
      "default": "./src/host-substrate.ts"
    },
    "./errors": {
      "types": "./src/runtime-errors.ts",
      "default": "./src/runtime-errors.ts"
    },
    "./tool-executor": {
      "types": "./src/agent-event-pipeline/subscribers/runtime-tool-use-executor.ts",
      "default": "./src/agent-event-pipeline/subscribers/runtime-tool-use-executor.ts"
    },
    "./control-plane": {
      "types": "./src/authorities/index.ts",
      "default": "./src/authorities/index.ts"
    },
    "./runtime-output": {
      "types": "./src/agent-event-pipeline/authorities/runtime-output-public.ts",
      "default": "./src/agent-event-pipeline/authorities/runtime-output-public.ts"
    },
    "./runtime-ingress": {
      "types": "./src/agent-event-pipeline/authorities/runtime-ingress-appender.ts",
      "default": "./src/agent-event-pipeline/authorities/runtime-ingress-appender.ts"
    },
    "./workflow-engine": {
      "types": "./src/workflow-engine/index.ts",
      "default": "./src/workflow-engine/index.ts"
    },
    "./durable-tools": {
      "types": "./src/durable-tools/index.ts",
      "default": "./src/durable-tools/index.ts"
    },
    "./events": {
      "types": "./src/agent-event-pipeline/events/index.ts",
      "default": "./src/agent-event-pipeline/events/index.ts"
    },
    "./codecs": {
      "types": "./src/agent-event-pipeline/codecs/index.ts",
      "default": "./src/agent-event-pipeline/codecs/index.ts"
    },
    "./agent-adapters": {
      "types": "./src/agent-adapters/index.ts",
      "default": "./src/agent-adapters/index.ts"
    },
    "./sources/sandbox": {
      "types": "./src/agent-event-pipeline/sources/sandbox/index.ts",
      "default": "./src/agent-event-pipeline/sources/sandbox/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.21.0",
    "@effect/ai": "^0.35.0",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "0.75.1",
    "@effect/workflow": "0.18.1",
    "@firegrid/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "effect": "^3.21.2",
    "effect-durable-operators": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
