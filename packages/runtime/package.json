{
  "name": "@firegrid/runtime",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./channels": {
      "types": "./src/channels/index.ts",
      "default": "./src/channels/index.ts"
    },
    "./streams": {
      "types": "./src/channels/observation-streams/index.ts",
      "default": "./src/channels/observation-streams/index.ts"
    },
    "./verified-webhook-ingest": {
      "types": "./src/verified-webhook-ingest/index.ts",
      "default": "./src/verified-webhook-ingest/index.ts"
    },
    "./unified": {
      "types": "./src/unified/index.ts",
      "default": "./src/unified/index.ts"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "default": "./src/events/index.ts"
    },
    "./sources/sandbox": {
      "types": "./src/sources/sandbox/index.ts",
      "default": "./src/sources/sandbox/index.ts"
    },
    "./sources/codecs/acp/stdio-edge": {
      "types": "./src/sources/codecs/acp/stdio-edge.ts",
      "default": "./src/sources/codecs/acp/stdio-edge.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "overview": "effect-language-service overview --project tsconfig.json",
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.21.0",
    "@durable-streams/server": "^0.3.1",
    "@effect/ai": "^0.35.0",
    "@effect/cli": "0.75.1",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "0.75.1",
    "@effect/workflow": "0.18.1",
    "@firegrid/observability": "workspace:*",
    "@firegrid/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "effect": "^3.21.2",
    "effect-durable-operators": "workspace:*"
  },
  "devDependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.36.1",
    "@firegrid/client-sdk": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
