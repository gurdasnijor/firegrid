{
  "name": "@firegrid/runtime",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./durable-clock": {
      "types": "./dist/durable-clock/index.d.ts",
      "default": "./dist/durable-clock/index.js"
    }
  },
  "bin": {
    "firegrid": "./dist/bin/firegrid.js",
    "fg": "./dist/bin/firegrid.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "firegrid": "tsx ./bin/firegrid.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@durable-streams/state": "^0.2.5",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "effect": "^3.18.0",
    "@durable-streams/server": "^0.3.1",
    "@durable-streams/client": "^0.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
