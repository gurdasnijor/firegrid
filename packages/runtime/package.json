{
  "name": "@firegrid/runtime",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./errors": {
      "types": "./src/runtime-errors.ts",
      "default": "./src/runtime-errors.ts"
    },
    "./channels": {
      "types": "./src/channels/index.ts",
      "default": "./src/channels/index.ts"
    },
    "./per-context-output": {
      "types": "./src/agent-event-pipeline/authorities/per-context-output.ts",
      "default": "./src/agent-event-pipeline/authorities/per-context-output.ts"
    },
    "./tool-executor": {
      "types": "./src/agent-event-pipeline/tool-execution/index.ts",
      "default": "./src/agent-event-pipeline/tool-execution/index.ts"
    },
    "./control-plane": {
      "types": "./src/control-plane/index.ts",
      "default": "./src/control-plane/index.ts"
    },
    "./runtime-output": {
      "types": "./src/agent-event-pipeline/authorities/runtime-output-public.ts",
      "default": "./src/agent-event-pipeline/authorities/runtime-output-public.ts"
    },
    "./streams": {
      "types": "./src/streams/index.ts",
      "default": "./src/streams/index.ts"
    },
    "./runtime-keyed-subscriber": {
      "types": "./src/runtime-keyed-subscriber/index.ts",
      "default": "./src/runtime-keyed-subscriber/index.ts"
    },
    "./verified-webhook-ingest": {
      "types": "./src/verified-webhook-ingest/index.ts",
      "default": "./src/verified-webhook-ingest/index.ts"
    },
    "./workflow-engine": {
      "types": "./src/workflow-engine/index.ts",
      "default": "./src/workflow-engine/index.ts"
    },
    "./kernel": {
      "types": "./src/kernel/index.ts",
      "default": "./src/kernel/index.ts"
    },
    "./workflows": {
      "types": "./src/workflow-engine/workflows/index.ts",
      "default": "./src/workflow-engine/workflows/index.ts"
    },
    "./events": {
      "types": "./src/agent-event-pipeline/events/index.ts",
      "default": "./src/agent-event-pipeline/events/index.ts"
    },
    "./channels": {
      "types": "./src/channels/index.ts",
      "default": "./src/channels/index.ts"
    },
    "./codecs": {
      "types": "./src/agent-event-pipeline/codecs/index.ts",
      "default": "./src/agent-event-pipeline/codecs/index.ts"
    },
    "./session-byte-stream-adapter": {
      "types": "./src/agent-event-pipeline/session-byte-stream-adapter.ts",
      "default": "./src/agent-event-pipeline/session-byte-stream-adapter.ts"
    },
    "./agent-adapters": {
      "types": "./src/agent-adapters/index.ts",
      "default": "./src/agent-adapters/index.ts"
    },
    "./sources/sandbox": {
      "types": "./src/agent-event-pipeline/sources/sandbox/index.ts",
      "default": "./src/agent-event-pipeline/sources/sandbox/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.21.0",
    "@effect/ai": "^0.35.0",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "0.75.1",
    "@effect/workflow": "0.18.1",
    "@firegrid/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "effect": "^3.21.2",
    "effect-durable-operators": "workspace:*"
  },
  "devDependencies": {
    "@agentclientprotocol/claude-agent-acp": "0.36.1",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
