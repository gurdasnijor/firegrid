{
  "name": "@firegrid/runtime",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./materialization": {
      "types": "./src/materialization/index.ts",
      "default": "./src/materialization/index.ts"
    },
    "./materialization/core": {
      "types": "./src/materialization/core/index.ts",
      "default": "./src/materialization/core/index.ts"
    },
    "./materialization/raw-fold": {
      "types": "./src/materialization/raw-fold/index.ts",
      "default": "./src/materialization/raw-fold/index.ts"
    },
    "./materialization/state-protocol": {
      "types": "./src/materialization/state-protocol/index.ts",
      "default": "./src/materialization/state-protocol/index.ts"
    },
    "./runtime-ingress": {
      "types": "./src/runtime-ingress/index.ts",
      "default": "./src/runtime-ingress/index.ts"
    },
    "./materialization/materialize": {
      "types": "./src/materialization/materialize/index.ts",
      "default": "./src/materialization/materialize/index.ts"
    }
  },
  "bin": {
    "firegrid": "./dist/bin/firegrid.js",
    "fg": "./dist/bin/firegrid.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "firegrid": "tsx ./bin/firegrid.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/experimental": "0.60.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "0.75.1",
    "@effect/sql": "0.51.1",
    "@effect/sql-pg": "0.52.1",
    "@effect/workflow": "0.18.1",
    "@firegrid/durable-streams": "workspace:*",
    "@firegrid/protocol": "workspace:*",
    "effect-durable-operators": "workspace:*",
    "effect-durable-streams": "workspace:*",
    "effect": "^3.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.20.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
