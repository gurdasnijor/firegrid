{
  "name": "@firegrid/runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "firegrid": "./bin/firegrid.ts",
    "fg": "./bin/firegrid.ts"
  },
  "scripts": {
