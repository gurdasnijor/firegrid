  "devDependencies": {
    "@durable-streams/server": "^0.3.1",
    "@durable-streams/state": "^0.2.5",
    "@types/node": "^22.10.0",
    "tsx": "^4.20.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
