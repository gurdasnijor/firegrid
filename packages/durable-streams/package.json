{
  "name": "@firegrid/durable-streams",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./test-utils": {
      "types": "./src/test-utils.ts",
      "default": "./src/test-utils.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/server": "^0.3.1",
    "@durable-streams/state": "^0.2.5",
    "@effect/workflow": "0.18.1",
    "@firegrid/protocol": "workspace:*",
    "effect": "^3.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
