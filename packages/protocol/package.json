{
  "name": "@firegrid/protocol",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./launch": {
      "types": "./src/launch/index.ts",
      "default": "./src/launch/index.ts"
    },
    "./runtime-ingress": {
      "types": "./src/runtime-ingress/index.ts",
      "default": "./src/runtime-ingress/index.ts"
    },
    "./session-facade": {
      "types": "./src/session-facade/index.ts",
      "default": "./src/session-facade/index.ts"
    },
    "./operations": {
      "types": "./src/operations/index.ts",
      "default": "./src/operations/index.ts"
    },
    "./otel": {
      "types": "./src/otel/index.ts",
      "default": "./src/otel/index.ts"
    },
    "./agent-tools": {
      "types": "./src/agent-tools/index.ts",
      "default": "./src/agent-tools/index.ts"
    },
    "./agent-output": {
      "types": "./src/agent-output/index.ts",
      "default": "./src/agent-output/index.ts"
    },
    "./observations": {
      "types": "./src/observations/index.ts",
      "default": "./src/observations/index.ts"
    },
    "./verified-webhook": {
      "types": "./src/verified-webhook/index.ts",
      "default": "./src/verified-webhook/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/ai": "^0.35.0",
    "effect": "^3.21.2",
    "effect-durable-operators": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
