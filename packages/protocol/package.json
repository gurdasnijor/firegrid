{
  "name": "@firegrid/protocol",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./launch": {
      "types": "./src/launch/index.ts",
      "default": "./src/launch/index.ts"
    },
    "./runtime-ingress": {
      "types": "./src/runtime-ingress/index.ts",
      "default": "./src/runtime-ingress/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect-durable-operators": "workspace:*",
    "effect": "^3.18.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
