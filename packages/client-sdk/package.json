{
  "name": "@firegrid/client-sdk",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./firegrid": {
      "types": "./src/firegrid.ts",
      "default": "./src/firegrid.ts"
    },
    "./operations": {
      "types": "./src/operations.ts",
      "default": "./src/operations.ts"
    },
    "./permission-auto-approve": {
      "types": "./src/permission-auto-approve.ts",
      "default": "./src/permission-auto-approve.ts"
    },
    "./mcp-durable-streams-spike": {
      "types": "./src/mcp-durable-streams-spike.ts",
      "default": "./src/mcp-durable-streams-spike.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/ai": "^0.35.0",
    "@effect/platform": "^0.96.1",
    "@effect/rpc": "0.75.1",
    "@firegrid/protocol": "workspace:*",
    "effect-durable-streams": "workspace:*",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
