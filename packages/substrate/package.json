{
  "name": "@firegrid/substrate",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./descriptors": {
      "types": "./dist/descriptors/index.d.ts",
      "default": "./dist/descriptors/index.js"
    },
    "./event-plane": {
      "types": "./dist/event-plane/index.d.ts",
      "default": "./dist/event-plane/index.js"
    },
    "./id-gen": {
      "types": "./dist/id-gen.d.ts",
      "default": "./dist/id-gen.js"
    },
    "./kernel": {
      "types": "./dist/kernel/index.d.ts",
      "default": "./dist/kernel/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "pnpm run typecheck && pnpm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/state": "^0.2.5",
    "@tanstack/db": "^0.5.0",
    "effect": "^3.18.0"
  },
  "devDependencies": {
    "@durable-streams/server": "^0.3.1",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
