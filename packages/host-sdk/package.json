{
  "name": "@firegrid/host-sdk",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./agent-tools": {
      "types": "./src/agent-tools/index.ts",
      "default": "./src/agent-tools/index.ts"
    },
    "./agent-tools/bindings": {
      "types": "./src/agent-tools/bindings/index.ts",
      "default": "./src/agent-tools/bindings/index.ts"
    },
    "./agent-tools/execution": {
      "types": "./src/agent-tools/execution/index.ts",
      "default": "./src/agent-tools/execution/index.ts"
    },
    "./host": {
      "types": "./src/host/index.ts",
      "default": "./src/host/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@effect/ai": "^0.35.0",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/rpc": "0.75.1",
    "@effect/workflow": "0.18.1",
    "@firegrid/protocol": "workspace:*",
    "@firegrid/runtime": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "effect": "^3.21.2",
    "effect-durable-operators": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
