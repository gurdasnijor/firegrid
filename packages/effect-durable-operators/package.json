{
  "name": "effect-durable-operators",
  "version": "0.0.0",
  "description": "Effect-native DurableTable: ksql-inspired service-tag table over @durable-streams/state and @tanstack/db.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./src/react.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/state": "^0.2.5",
    "@effect/platform": "^0.96.0",
    "@tanstack/db": "^0.5.33",
    "@tanstack/react-db": "0.1.77",
    "effect": "^3.18.0",
    "react": "^18.3.1"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-db": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "effect-durable-streams": "workspace:*"
  },
  "devDependencies": {
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/state": "^0.2.5",
    "@effect/platform": "^0.96.1",
    "@tanstack/db": "^0.5.33",
    "@tanstack/react-db": "0.1.77",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.28",
    "effect": "^3.21.2",
    "react": "^18.3.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
