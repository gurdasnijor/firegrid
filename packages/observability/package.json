{
  "name": "@firegrid/observability",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./src/node.ts"
    }
  },
  "scripts": {
    "diagnostics": "node ../../tooling/src/effect-diagnostics-check.ts",
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/opentelemetry": "0.63.0",
    "@effect/platform-node": "^0.106.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
