{
  "name": "@firegrid/durable-streams-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Vendored copy of durable-streams examples/test-ui — a stream inspector pointed at http://localhost:4437, for watching a live Firegrid host's durable streams. Not Firegrid-aware; shows raw stream paths/rows.",
