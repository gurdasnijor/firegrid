    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/state": "^0.2.5",
    "@tanstack/react-db": "latest",
    "@tanstack/react-router": "^1.139.14",
    "@tanstack/react-virtual": "^3.13.13",
    "@tanstack/router-devtools": "^1.139.15",
    "@tanstack/router-plugin": "^1.139.14",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-json-view": "^1.21.3"
  }
