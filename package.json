{
  "name": "firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm run lint && pnpm run effect:diagnostics && turbo run build check",
    "effect:diagnostics": "turbo run diagnostics",
    "effect:patch": "effect-language-service patch",
    "effect:unpatch": "effect-language-service unpatch",
    "firegrid": "tsx packages/runtime/src/bin/firegrid.ts",
    "firegrid:env": "node --env-file-if-exists=.env --import tsx packages/runtime/src/bin/firegrid.ts",
    "format": "eslint . --fix",
    "publish:oss": "bash scripts/publish-oss.sh",
    "lint": "eslint . --max-warnings 0 --cache --cache-location .eslintcache",
    "lint:dead": "knip --treat-config-hints-as-errors",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages && depcruise --config .dependency-cruiser.cjs --include-only '(^packages/.*/src|^packages/tiny-firegrid/test)' packages/tiny-firegrid/test",
    "lint:dup": "jscpd packages/*/src",
    "preflight": "turbo run lint lint:dead lint:dup lint:deps typecheck test diagnostics trace:seams:ukv --continue --output-logs=errors-only",
    "trace:seams": "pnpm --filter @firegrid/tiny-firegrid run trace:seams",
    "trace:seams:ukv": "pnpm --filter @firegrid/tiny-firegrid run trace:seams:ukv",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run preflight"
  },
  "devDependencies": {
    "@durable-streams/server": "^0.3.1",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.85.1",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "tsx": "^4.20.4",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
