{
  "name": "firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm run lint && pnpm run effect:diagnostics && turbo run build check",
    "effect:diagnostics": "turbo run diagnostics",
    "effect:overview": "effect-language-service overview --project packages/runtime/tsconfig.json",
    "effect:layerinfo": "effect-language-service layerinfo",
    "effect:quickfixes": "effect-language-service quickfixes --project packages/runtime/tsconfig.json",
    "effect:patch": "effect-language-service patch",
    "effect:unpatch": "effect-language-service unpatch",
    "firegrid": "tsx packages/runtime/src/bin/firegrid.ts",
    "firegrid:env": "node --env-file-if-exists=.env --import tsx packages/runtime/src/bin/firegrid.ts",
    "firelab": "pnpm --filter firelab exec tsx src/index.ts",
    "firelab:list": "pnpm --filter firelab exec tsx src/index.ts list",
    "firelab:run": "pnpm --filter firelab exec tsx src/index.ts run",
    "firelab:seams": "pnpm --filter firelab exec tsx src/index.ts seams",
    "firelab:gaps": "pnpm --filter firelab exec tsx src/index.ts gaps",
    "firelab:runs": "pnpm --filter firelab exec tsx src/index.ts runs",
    "firelab:show": "pnpm --filter firelab exec tsx src/index.ts show",
    "inventory:operations": "tsx scripts/operation-inventory.ts",
    "inventory:schemas": "tsx scripts/schema-inventory.ts",
    "audit:exports": "tsx scripts/package-exports-audit.ts",
    "format": "eslint . --fix",
    "publish:oss": "bash scripts/publish-oss.sh",
    "lint": "eslint . --max-warnings 0 --cache --cache-location .eslintcache",
    "lint:dead": "knip --treat-config-hints-as-errors",
    "gate:test-only-exports": "tsx scripts/test-only-export-gate.ts",
    "gate:contract-id": "tsx scripts/contract-id-canonical-gate.ts",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages && depcruise --config .dependency-cruiser.cjs --include-only '(^packages/.*/src|^packages/firelab/test)' packages/firelab/test && tsx scripts/contract-id-canonical-gate.ts",
    "lint:dup": "jscpd packages/*/src",
    "preflight": "turbo run lint lint:dead lint:dup lint:deps typecheck test diagnostics coverage:gate --continue --output-logs=errors-only",
    "coverage:gate": "pnpm --filter firelab run coverage:gate",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run preflight"
  },
  "devDependencies": {
    "@durable-streams/server": "0.3.7",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.86.2",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "tsx": "^4.20.4",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  },
  "pnpm": {
    "overrides": {
      "@durable-streams/server": "github:gurdasnijor/durable-streams#4a5efcf35d67bf16697b2f965860cffdebde1dcb&path:/packages/server",
      "@firegrid/durable-streams-ui>@tanstack/react-db": "0.1.85"
    }
  }
}
