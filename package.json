{
  "name": "firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "turbo run build",
    "check": "pnpm run check:specs && pnpm run check:docs && pnpm run lint && pnpm run effect:diagnostics && turbo run build check",
    "check:specs": "node scripts/tooling.mjs check specs",
    "check:docs": "node scripts/tooling.mjs check docs",
    "effect:check": "effect-language-service check",
    "effect:diagnostics": "turbo run diagnostics",
    "effect:diagnostics:baseline": "turbo run diagnostics --force -- --update-baseline",
    "effect:patch": "effect-language-service patch",
    "effect:unpatch": "effect-language-service unpatch",
    "firegrid:host": "tsx packages/runtime/src/bin/host.ts",
    "firegrid:host:env": "node --env-file-if-exists=.env --import tsx packages/runtime/src/bin/host.ts",
    "firegrid:acp": "tsx packages/runtime/src/bin/acp.ts",
    "firegrid:run": "tsx packages/runtime/src/bin/run.ts",
    "firegrid:start": "tsx packages/runtime/src/bin/start.ts",
    "firegrid": "tsx packages/runtime/src/bin/firegrid.ts",
    "format": "eslint . --fix",
    "publish:oss": "bash scripts/publish-oss.sh",
    "lint": "eslint . --max-warnings 0 --cache --cache-location .eslintcache && node scripts/runtime-public-surface-check.mjs && node scripts/tiny-firegrid-layout-check.mjs",
    "lint:dead": "node scripts/knip-check-baseline.mjs",
    "lint:dead:baseline": "node scripts/knip-update-baseline.mjs",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages && depcruise --config .dependency-cruiser.cjs --include-only '(^packages/.*/src|^packages/tiny-firegrid/test)' packages/tiny-firegrid/test",
    "lint:dup": "node scripts/jscpd-check-baseline.mjs",
    "lint:dup:baseline": "node scripts/jscpd-update-baseline.mjs",
    "lint:effect-quality": "node scripts/effect-quality-metrics-check.mjs",
    "lint:effect-quality:baseline": "node scripts/effect-quality-metrics-baseline.mjs",
    "preflight": "pnpm --filter tooling run preflight",
    "arch:deps": "node scripts/tooling.mjs arch deps all",
    "arch:deps:detail": "node scripts/tooling.mjs arch deps detail",
    "arch:deps:workspace": "node scripts/tooling.mjs arch deps workspace",
    "arch:deps:workspace:detail": "node scripts/tooling.mjs arch deps workspace-detail",
    "arch:deps:client": "node scripts/tooling.mjs arch deps client",
    "arch:deps:protocol": "node scripts/tooling.mjs arch deps protocol",
    "arch:deps:runtime": "node scripts/tooling.mjs arch deps runtime",
    "arch:deps:runtime:detail": "node scripts/tooling.mjs arch deps runtime-detail",
    "arch:graphs": "pnpm run arch:deps && pnpm run arch:deps:detail",
    "toy:coverage": "bash scripts/tiny-config-prod-coverage.sh",
    "trace:seams": "tsx scripts/trace-seam-coverage.ts",
    "trace:seams:ukv": "pnpm --filter @firegrid/tiny-firegrid run trace:seams:ukv",
    "analysis:leaf": "bash tooling/analysis/run-leaf-inventory.sh",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run check:specs && pnpm run check:docs && pnpm run typecheck && pnpm run lint && pnpm run lint:dead && pnpm run lint:dup && pnpm run lint:deps && pnpm run lint:effect-quality && pnpm run lint:host-sdk-imports && pnpm run test",
    "toy:coverage:check": "bash scripts/tiny-config-prod-coverage.sh --check"
  },
  "devDependencies": {
    "@durable-streams/server": "^0.3.1",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.85.1",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.20.4",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
