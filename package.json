{
  "name": "firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "turbo run build",
    "check": "pnpm run check:specs && pnpm run check:docs && pnpm run lint && turbo run build check",
    "check:specs": "node scripts/tooling.mjs check specs",
    "check:docs": "node scripts/tooling.mjs check docs",
    "effect:check": "effect-language-service check",
    "effect:diagnostics": "node scripts/tooling.mjs effect diagnostics",
    "effect:diagnostics:baseline": "node scripts/tooling.mjs effect diagnostics --update-baseline",
    "effect:patch": "effect-language-service patch",
    "effect:unpatch": "effect-language-service unpatch",
    "firegrid": "tsx packages/cli/src/bin/run.ts",
    "firegrid:env": "node --env-file-if-exists=.env --import tsx packages/cli/src/bin/run.ts",
    "firegrid:host": "tsx packages/cli/src/bin/index.ts",
    "firegrid:host:env": "node --env-file-if-exists=.env --import tsx packages/cli/src/bin/index.ts",
    "firegrid:run": "tsx packages/cli/src/bin/run.ts run",
    "firegrid:run:env": "node --env-file-if-exists=.env --import tsx packages/cli/src/bin/run.ts run",
    "firegrid:start": "tsx packages/cli/src/bin/run.ts start",
    "firegrid:start:env": "node --env-file-if-exists=.env --import tsx packages/cli/src/bin/run.ts start",
    "format": "eslint . --fix",
    "lint": "eslint . --max-warnings 0 && node scripts/effect-native-production-cutover-check.mjs && node scripts/runtime-public-surface-check.mjs && node scripts/test-layout-check.mjs && pnpm run effect:diagnostics",
    "lint:test-layout": "node scripts/test-layout-check.mjs",
    "lint:dead": "node scripts/knip-check-baseline.mjs",
    "lint:dead:baseline": "node scripts/knip-update-baseline.mjs",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages",
    "lint:dup": "node scripts/jscpd-check-baseline.mjs",
    "lint:dup:baseline": "node scripts/jscpd-update-baseline.mjs",
    "lint:effect-quality": "node scripts/effect-quality-metrics-check.mjs",
    "lint:effect-quality:baseline": "node scripts/effect-quality-metrics-baseline.mjs",
    "lint:ast-grep": "sg scan --config tooling/ast-grep/sgconfig.yml --filter hrtime-number-arithmetic --error=hrtime-number-arithmetic packages",
    "lint:semgrep": "node scripts/semgrep-check-baseline.mjs",
    "lint:semgrep:report": "semgrep --config .semgrep.yml packages",
    "lint:semgrep:test": "semgrep --test --config .semgrep.yml semgrep-tests/dup-detection.ts",
    "preflight": "node scripts/preflight.mjs",
    "arch:deps": "node scripts/tooling.mjs arch deps all",
    "arch:deps:detail": "node scripts/tooling.mjs arch deps detail",
    "arch:deps:workspace": "node scripts/tooling.mjs arch deps workspace",
    "arch:deps:workspace:detail": "node scripts/tooling.mjs arch deps workspace-detail",
    "arch:deps:client": "node scripts/tooling.mjs arch deps client",
    "arch:deps:protocol": "node scripts/tooling.mjs arch deps protocol",
    "arch:deps:runtime": "node scripts/tooling.mjs arch deps runtime",
    "arch:deps:runtime:detail": "node scripts/tooling.mjs arch deps runtime-detail",
    "toy:coverage": "bash scripts/tiny-config-prod-coverage.sh",
    "analysis:leaf": "bash tooling/analysis/run-leaf-inventory.sh",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run check:specs && pnpm run check:docs && pnpm run typecheck && pnpm run lint && pnpm run lint:dead && pnpm run lint:dup && pnpm run lint:deps && pnpm run lint:effect-quality && pnpm run lint:ast-grep && pnpm run lint:semgrep:test && pnpm run lint:semgrep && pnpm run test",
    "toy:coverage:check": "bash scripts/tiny-config-prod-coverage.sh --check"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.2",
    "@durable-streams/server": "^0.3.1",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.85.1",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.20.4",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
