{
  "name": "firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "turbo run build",
    "check": "pnpm run check:specs && pnpm run check:docs && pnpm run lint && turbo run build check",
    "check:specs": "ruby -e 'require \"yaml\"; ARGV.each { |f| YAML.load_file(f); puts \"ok #{File.basename(f)}\" }' features/*/*.feature.yaml",
    "check:docs": "find README.md docs features -type f \\( -name '*.md' -o -name '*.yaml' \\) -print0 | xargs -0 perl -ne 'print \"$ARGV:$.: trailing whitespace\\n\" if /[ \\t]$/; close ARGV if eof' && ! grep -R -n -E '<<<<<<<|>>>>>>>|=======' README.md docs features",
    "effect:check": "effect-language-service check",
    "effect:diagnostics": "sh -c 'status=0; for f in packages/*/tsconfig.json apps/*/tsconfig.json; do [ -f \"$f\" ] || continue; echo \"== $f ==\"; effect-language-service diagnostics --project \"$f\" --format text || status=$?; done; exit \"$status\"'",
    "effect:patch": "effect-language-service patch",
    "effect:unpatch": "effect-language-service unpatch",
    "format": "eslint . --fix",
    "lint": "eslint . --max-warnings 0",
    "lint:dead": "node scripts/knip-check-baseline.mjs",
    "lint:dead:baseline": "node scripts/knip-update-baseline.mjs",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages apps",
    "lint:dup": "node scripts/jscpd-check-baseline.mjs",
    "lint:dup:baseline": "node scripts/jscpd-update-baseline.mjs",
    "lint:effect-quality": "node scripts/effect-quality-metrics-check.mjs",
    "lint:effect-quality:baseline": "node scripts/effect-quality-metrics-baseline.mjs",
    "lint:semgrep": "semgrep --error --config .semgrep.yml packages apps",
    "lint:semgrep:test": "semgrep --test --config .semgrep.yml semgrep-tests/dup-detection.ts",
    "arch:deps": "pnpm run arch:deps:workspace && pnpm run arch:deps:client && pnpm run arch:deps:protocol && pnpm run arch:deps:runtime && pnpm run arch:deps:flamecast",
    "arch:deps:detail": "pnpm run arch:deps:workspace:detail && pnpm run arch:deps:runtime:detail && pnpm run arch:deps:runtime:durable-launch:detail && pnpm run arch:deps:flamecast:detail",
    "arch:deps:workspace": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' packages apps --output-type mermaid --collapse '^(packages|apps)/[^/]+/src/[^/]+' > docs/dependency-graph.mmd",
    "arch:deps:workspace:detail": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' packages apps --output-type mermaid > docs/dependency-graph-detail.mmd",
    "arch:deps:client": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' packages/client/src --output-type mermaid --collapse '^packages/client/src/[^/]+' > docs/dependency-graph-client.mmd",
    "arch:deps:protocol": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' packages/protocol/src --output-type mermaid --collapse '^packages/protocol/src/[^/]+' > docs/dependency-graph-protocol.mmd",
    "arch:deps:runtime": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' packages/runtime/src --output-type mermaid --collapse '^packages/runtime/src/[^/]+' > docs/dependency-graph-runtime.mmd",
    "arch:deps:runtime:detail": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' packages/runtime/src --output-type mermaid > docs/dependency-graph-runtime-detail.mmd",
    "arch:deps:runtime:durable-launch:detail": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' packages/runtime/src/durable-launch --output-type mermaid > docs/dependency-graph-runtime-durable-launch-detail.mmd",
    "arch:deps:flamecast": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' apps/flamecast/src --output-type mermaid --collapse '^apps/flamecast/src/[^/]+' > docs/dependency-graph-flamecast.mmd",
    "arch:deps:flamecast:detail": "depcruise --config .dependency-cruiser.cjs --exclude '(^|/)(.*\\.test\\.(ts|tsx|mts)|__tests__|dist|build|coverage)(/|$)' apps/flamecast/src --output-type mermaid > docs/dependency-graph-flamecast-detail.mmd",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run lint:dead && pnpm run lint:dup && pnpm run lint:deps && pnpm run lint:effect-quality && pnpm run lint:semgrep:test && pnpm run lint:semgrep && pnpm run test"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.85.1",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "ts-morph": "^28.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
