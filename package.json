{
  "name": "firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "turbo run build",
    "check": "pnpm run check:specs && pnpm run check:docs && pnpm run lint && turbo run build check",
    "check:specs": "node scripts/tooling.mjs check specs",
    "check:docs": "node scripts/tooling.mjs check docs",
    "effect:check": "effect-language-service check",
    "effect:diagnostics": "node scripts/tooling.mjs effect diagnostics",
    "effect:patch": "effect-language-service patch",
    "effect:unpatch": "effect-language-service unpatch",
    "firegrid": "tsx src/run.ts",
    "firegrid:env": "node --env-file-if-exists=.env --import tsx src/run.ts",
    "firegrid:host": "tsx src/index.ts",
    "firegrid:host:env": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "firegrid:run": "tsx src/run.ts run",
    "firegrid:run:env": "node --env-file-if-exists=.env --import tsx src/run.ts run",
    "firegrid:start": "tsx src/run.ts start",
    "firegrid:start:env": "node --env-file-if-exists=.env --import tsx src/run.ts start",
    "smoke:firegrid-run": "pnpm --filter @firegrid/scenario-firegrid exec vitest run src/tracer-019-sync-run.test.ts",
    "flamecast:dev": "pnpm --filter @firegrid/flamecast dev:local",
    "flamecast:run": "pnpm --filter @firegrid/flamecast run:env",
    "format": "eslint . --fix",
    "lint": "eslint . --max-warnings 0 && node scripts/effect-native-production-cutover-check.mjs",
    "lint:dead": "node scripts/knip-check-baseline.mjs",
    "lint:dead:baseline": "node scripts/knip-update-baseline.mjs",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages apps",
    "lint:dup": "node scripts/jscpd-check-baseline.mjs",
    "lint:dup:baseline": "node scripts/jscpd-update-baseline.mjs",
    "lint:effect-quality": "node scripts/effect-quality-metrics-check.mjs",
    "lint:effect-quality:baseline": "node scripts/effect-quality-metrics-baseline.mjs",
    "lint:semgrep": "node scripts/semgrep-check-baseline.mjs",
    "lint:semgrep:report": "semgrep --config .semgrep.yml packages apps",
    "lint:semgrep:test": "semgrep --test --config .semgrep.yml semgrep-tests/dup-detection.ts",
    "preflight": "node scripts/preflight.mjs",
    "arch:deps": "node scripts/tooling.mjs arch deps all",
    "arch:deps:detail": "node scripts/tooling.mjs arch deps detail",
    "arch:deps:workspace": "node scripts/tooling.mjs arch deps workspace",
    "arch:deps:workspace:detail": "node scripts/tooling.mjs arch deps workspace-detail",
    "arch:deps:client": "node scripts/tooling.mjs arch deps client",
    "arch:deps:protocol": "node scripts/tooling.mjs arch deps protocol",
    "arch:deps:runtime": "node scripts/tooling.mjs arch deps runtime",
    "arch:deps:runtime:detail": "node scripts/tooling.mjs arch deps runtime-detail",
    "arch:deps:flamecast": "node scripts/tooling.mjs arch deps flamecast",
    "arch:deps:flamecast:detail": "node scripts/tooling.mjs arch deps flamecast-detail",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run lint:dead && pnpm run lint:dup && pnpm run lint:deps && pnpm run lint:effect-quality && pnpm run lint:semgrep:test && pnpm run lint:semgrep && pnpm run test"
  },
  "dependencies": {
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "@effect/typeclass": "^0.40.0",
    "@firegrid/protocol": "workspace:*",
    "@firegrid/runtime": "workspace:*",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@durable-streams/server": "^0.3.1",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.85.1",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.20.4",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
