{
  "$schema": "https://turbo.build/schema.json",
  "cacheDir": ".turbo/cache",
  "globalDependencies": ["tooling/src/effect-diagnostics-check.ts"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "diagnostics": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@firegrid/tiny-firegrid#test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false
    },
    "check": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}
