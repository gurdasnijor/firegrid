{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@firegrid/runtime": ["../../packages/runtime/src/index.ts"],
      "@firegrid/runtime/durable-clock": ["../../packages/runtime/src/durable-clock/index.ts"],
      "@firegrid/runtime/*": ["../../packages/runtime/src/*"]
    },
    "skipLibCheck": true,
    "target": "ES2022",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
