{
  "name": "@firegrid/flamecast",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build",
    "dev": "vite --host 127.0.0.1",
    "runtime": "tsx --tsconfig tsconfig.json src/runtime/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/workflow": "0.18.1",
    "@firegrid/durable-streams": "workspace:*",
    "effect": "^3.18.0",
    "effect-durable-streams": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.20.4",
    "typescript": "^5.9.3",
    "vite": "^6.0.5",
    "vitest": "^3.2.0"
  }
}
